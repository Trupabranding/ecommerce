APP_NAME="Laravel Filament Ecommerce"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://ecom.test

DEBUGBAR_ENABLED=false
TELESCOPE_ENABLED=false
PULSE_ENABLED=false

DB_CONNECTION=sqlite
DB_DATABASE=database/database.sqlite

# For production or Docker-backed local environments, switch back to MySQL / Redis.
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel_filament_ecommerce
# DB_USERNAME=root
# DB_PASSWORD=secret

QUEUE_CONNECTION=sync
SESSION_DRIVER=file
API_RATE_LIMIT_REDIS=false
HORIZON_ENABLED=false
HEALTH_QUEUE_ENABLED=false
HEALTH_REDIS_ENABLED=false
BRANCH_FEATURE_ENABLED=false
BRANCH_FEATURE_LICENSE_HASH=
# Keep plaintext license key out of git and local files when possible.
# BRANCH_FEATURE_LICENSE_KEY=

# disk
FILESYSTEM_DISK=local
FILAMENT_FILESYSTEM_DISK=public
MEDIA_DISK=public
BACKUP_DISK=local

CACHE_STORE=array
SETTINGS_CACHE_ENABLED=false
#MAIL_MAILER=helo-homestead

# mailtrap
MAIL_USERNAME=null
MAIL_PASSWORD=null

# gmail email set up
#MAIL_HOST=smtp.googlemail.com
#MAIL_PORT=587
#MAIL_USERNAME=ENTER_YOUR_GMAIL_USERNAME
#MAIL_PASSWORD=ENTER_YOUR_GMAIL_APP_PASSWORD
#MAIL_ENCRYPTION=tls

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false
AWS_URL=null

# sail minio https://laravel.com/docs/master/sail#file-storage
# access in browser http://localhost:8900
# username: sail
# password: password
#AWS_ACCESS_KEY_ID=sail
#AWS_SECRET_ACCESS_KEY=password
#AWS_DEFAULT_REGION=us-east-1
#AWS_BUCKET=local
#AWS_ENDPOINT=http://minio:9000
#AWS_USE_PATH_STYLE_ENDPOINT=true
#AWS_URL=http://localhost:9000/local

# homestead minio https://laravel.com/docs/master/homestead#configuring-minio
#AWS_ACCESS_KEY_ID=homestead
#AWS_SECRET_ACCESS_KEY=secretkey
#AWS_DEFAULT_REGION=us-east-1
#AWS_BUCKET=laravel-filament-ecommerce
#AWS_ENDPOINT=http://192.168.56.56:9600
#AWS_USE_PATH_STYLE_ENDPOINT=false
#AWS_URL=null

AWS_DB_BACKUP_ACCESS_KEY_ID="${AWS_ACCESS_KEY_ID}"
AWS_DB_BACKUP_SECRET_ACCESS_KEY="${AWS_SECRET_ACCESS_KEY}"
AWS_DB_BACKUP_DEFAULT_REGION="${AWS_DEFAULT_REGION}"
AWS_DB_BACKUP_BUCKET="${AWS_BUCKET}"
AWS_DB_BACKUP_ENDPOINT="${AWS_ENDPOINT}"
AWS_DB_BACKUP_USE_PATH_STYLE_ENDPOINT="${AWS_USE_PATH_STYLE_ENDPOINT}"
AWS_DB_BACKUP_URL="${AWS_URL}"

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# Choose your preferred editor to use when clicking any edit button. see config/ignition.php (publish config if need)
IGNITION_EDITOR=phpstorm
# example for homestead: /home/vagrant/code/laravel-filament-ecommerce
IGNITION_REMOTE_SITES_PATH=
IGNITION_LOCAL_SITES_PATH=

# https://myray.app/
RAY_REMOTE_PATH="${IGNITION_REMOTE_SITES_PATH}"
RAY_LOCAL_PATH="${IGNITION_LOCAL_SITES_PATH}"

# https://sentry.io/for/laravel/
SENTRY_LARAVEL_DSN=
#SENTRY_TRACES_SAMPLE_RATE=0.2

NIGHTWATCH_TOKEN=
NIGHTWATCH_EXCEPTION_SAMPLE_RATE=0
NIGHTWATCH_INGEST_URI=127.0.0.1:2407

# password: secret
SUPER_ADMIN_PASSWORD_HASH="$2y$10$30Em8lVElUcSk/CKIbqsqO6SFLVXOsUsYbwG4J3BiXMoPoYH8EXJS"
SUPER_ADMIN_NAME="Business Owner"
SUPER_ADMIN_EMAIL="owner@example.com"

#LARAVEL_ENV_ENCRYPTION_KEY=

