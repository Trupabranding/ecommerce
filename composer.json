{
    "name": "lloricode/laravel-filament-ecommerce",
    "description": "Ecommerce made using Laravel and Filament",
    "type": "project",
    "keywords": [
        "project",
        "filament",
        "ecommerce"
    ],
    "license": "proprietary",
    "authors": [
        {
            "name": "Lloric Mayuga Garcia",
            "email": "lloricode@gmail.com",
            "homepage": "https://github.com/lloricode",
            "role": "Developer"
        }
    ],
    "homepage": "https://github.com/lloricode",
    "require": {
        "php": "^8.5",
        "aaronfrancis/fast-paginate": "^2.0",
        "bezhansalleh/filament-language-switch": "^4.1.0",
        "brick/money": "^0.11.1|^0.12",
        "charrafimed/global-search-modal": "^5.0",
        "dedoc/scramble": "^0.13.13",
        "filament/filament": "^5.2.1",
        "filament/spatie-laravel-media-library-plugin": "^5.2.1",
        "filament/spatie-laravel-settings-plugin": "^5.2.1",
        "filament/spatie-laravel-tags-plugin": "^5.2.1",
        "flowframe/laravel-trend": "^0.4",
        "guzzlehttp/guzzle": "^7.10.0",
        "khill/php-duration": "^1.1",
        "laravel/framework": "^12.51.0",
        "laravel/horizon": "^5.44.0",
        "laravel/nightwatch": "^1.22.1",
        "laravel/sanctum": "^4.3.1",
        "laravel/tinker": "^2.11.1",
        "laraveldaily/laravel-invoices": "^4.1.1",
        "league/flysystem-aws-s3-v3": "^3.31.0",
        "lloricode/filament-spatie-laravel-permission-plugin": "^2.0.1",
        "lloricode/php-timezone": "^1.1.1",
        "lloricode/spatie-image-optimizer-health-check": "^2.0.4",
        "maatwebsite/excel": "^3.1.67",
        "martinpetricko/filament-sentry-feedback": "^2.1.0",
        "mike42/escpos-php": "^4.0",
        "mpdf/mpdf": "^8.2.7",
        "opcodesio/log-viewer": "^3.21.1",
        "pxlrbt/filament-environment-indicator": "^3.4",
        "sentry/sentry-laravel": "^4.20.1",
        "shuvroroy/filament-spatie-laravel-backup": "^3.3",
        "shuvroroy/filament-spatie-laravel-health": "^3.2.0",
        "spatie/cpu-load-health-check": "^1.0.5",
        "spatie/eloquent-sortable": "^5.0.1",
        "spatie/laravel-activitylog": "^4.11.0",
        "spatie/laravel-backup": "^9.4.0",
        "spatie/laravel-json-api-paginate": "^2.0",
        "spatie/laravel-permission": "^7.2.3",
        "spatie/laravel-query-builder": "^6.4.1",
        "spatie/laravel-route-attributes": "^1.26.3",
        "spatie/laravel-schedule-monitor": "^4.1.0",
        "spatie/laravel-support-bubble": "^1.9.0",
        "spatie/opening-hours": "^4.2.1",
        "spatie/php-cloneable": "^1.0.2",
        "spatie/security-advisories-health-check": "^1.3.1",
        "stechstudio/filament-impersonate": "^5.1",
        "timacdonald/json-api": "^1.0.0-beta.11",
        "victord11/ssl-certification-health-check": "^1.0.5"
    },
    "require-dev": {
        "barryvdh/laravel-ide-helper": "^3.6.1",
        "beyondcode/helo-laravel": "^2.0.1",
        "canvural/larastan-strict-rules": "^3.0.3",
        "driftingly/rector-laravel": "^2.1.9",
        "fakerphp/faker": "^1.24.1",
        "fruitcake/laravel-debugbar": "^4.0.7",
        "larastan/larastan": "^3.9.2",
        "laravel/pint": "^1.27.1",
        "laravel/sail": "^1.53.0",
        "laravel/telescope": "^5.17.0",
        "mockery/mockery": "^1.6.12",
        "nunomaduro/collision": "^8.8.3",
        "pestphp/pest": "^4.3.2",
        "pestphp/pest-plugin-laravel": "^4.0",
        "pestphp/pest-plugin-livewire": "^4.1.0",
        "phpstan/extension-installer": "^1.4.3",
        "phpstan/phpstan": "^2.1.39",
        "phpstan/phpstan-deprecation-rules": "^2.0.4",
        "phpstan/phpstan-strict-rules": "^2.0.10",
        "rector/rector": "^2.3.6",
        "smknstd/fakerphp-picsum-images": "^1.0.3",
        "spatie/laravel-horizon-watcher": "^1.1.4",
        "spatie/laravel-ignition": "^2.10.0",
        "spatie/laravel-ray": "^1.43.5",
        "spatie/pest-plugin-test-time": "^2.2.1",
        "ticketswap/phpstan-error-formatter": "^1.2.4",
        "tomasvotruba/type-coverage": "^2.1.0",
        "worksome/request-factories": "^3.4"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/",
            "Database\\Support\\": "database/supports/",
            "Domain\\": "domain/",
            "Support\\": "support/"
        },
        "files": [
            "app/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true,
            "phpstan/extension-installer": true
        },
        "optimize-autoloader": true,
        "platform": {
            "php": "8.5"
        },
        "preferred-install": "dist",
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "dont-discover": [
                "laravel/telescope"
            ]
        }
    },
    "scripts": {
        "post-install-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force",
            "@php artisan filament:upgrade --ansi",
            "@php artisan vendor:publish --tag=log-viewer-assets --ansi --force",
            "@php artisan vendor:publish --tag=horizon-assets --ansi --force",
            "@php artisan vendor:publish --tag=telescope-assets --ansi --force"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force",
            "@php artisan filament:upgrade --ansi",
            "@php artisan log-viewer:publish",
            "@php artisan telescope:publish",
            "@php artisan ide-helper:generate --ansi",
            "@php artisan ide-helper:meta --ansi"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ],
        "format": "vendor/bin/pint -p --ansi",
        "format-dirty": "vendor/bin/pint -p --ansi --dirty",
        "format-dry-run": "vendor/bin/pint -p --ansi --test",
        "format-ci": "vendor/bin/pint -p --ansi --test",
        "ide-helper": [
            "Illuminate\\Foundation\\ComposerScripts::postUpdate",
            "@php artisan ide-helper:generate --ansi",
            "@php artisan ide-helper:meta --ansi"
        ],
        "ide-helper-model": [
            "Illuminate\\Foundation\\ComposerScripts::postUpdate",
            "@php artisan ide-helper:generate --ansi",
            "@php artisan ide-helper:meta --ansi",
            "@php artisan ide-helper:models --reset --write --ansi"
        ],
        "refactor": "vendor/bin/rector process --ansi",
        "refactor-dry-run": "vendor/bin/rector process --ansi --dry-run",
        "refactor-dry-run-no-timeout": [
            "Composer\\Config::disableProcessTimeout",
            "vendor/bin/rector process --ansi --dry-run"
        ],
        "refactor-no-timeout": [
            "Composer\\Config::disableProcessTimeout",
            "vendor/bin/rector process --ansi"
        ],
        "refactor-ci": "vendor/bin/rector process --ansi --dry-run",
        "test": "vendor/bin/pest -p",
        "test-no-timeout": ["Composer\\Config::disableProcessTimeout", "vendor/bin/pest -p"],
        "test-stop-on-f": "vendor/bin/pest -p --stop-on-failure --stop-on-error",
        "test-type-coverage": "vendor/bin/pest --type-coverage",
        "test-ci": "vendor/bin/pest -p --ci",
        "test-coverage": "vendor/bin/pest -p --coverage",
        "test-profanity": "vendor/bin/pest -p --profanity",
        "analyse": "vendor/bin/phpstan analyse --ansi",
        "analyse-ci": "vendor/bin/phpstan analyse --ansi",
        "analyse-debug": "vendor/bin/phpstan analyse --ansi --debug",
        "analyse-pro": "vendor/bin/phpstan analyse --ansi --pro",
        "analyse-pro-no-timeout": ["Composer\\Config::disableProcessTimeout", "vendor/bin/phpstan analyse --ansi --pro"],
        "analyse-no-memory-limit": "vendor/bin/phpstan analyse --ansi --memory-limit=-1",
        "analyse-generate-baseline": "vendor/bin/phpstan analyse --ansi --generate-baseline"
    }
}
